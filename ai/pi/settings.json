{
  "theme": "light",
  "lastChangelogVersion": "0.79.0",
  "hideThinkingBlock": true,
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "high",
  "autocompleteMaxVisible": 16,
  "skills": [
    "../skills"
  ],
  "packages": [
    "./node_modules/pi-mcp-adapter"
  ],
  "extensions": [
    "./extensions/apply-patch/index.ts",
    "./extensions/collapse-tool-calls/index.ts",
    "./extensions/compact-tool-output/index.ts",
    "./extensions/context/index.ts",
    "./extensions/ephemeral-fork/index.ts",
    "./extensions/fuzzy-at-file-autocomplete/index.ts",
    "./extensions/draft-stash/index.ts",
    "./extensions/openai-codex/index.ts",
    "./extensions/personal-context/index.ts",
    "./extensions/response-status/index.ts",
    "./extensions/tilth-cli/index.ts",
    "./extensions/write-file/index.ts"
  ],
  "prompts": [
    "../prompts"
  ],
  "retry": {
    "enabled": true,
    "maxRetries": 5,
    "baseDelayMs": 3000
  },
  "shellPath": "/usr/bin/bash",
  "enabledModels": [
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.5"
  ],
  "treeFilterMode": "no-tools",
  "transport": "websocket-cached",
  "terminal": {
    "showTerminalProgress": false
  },
  "enableInstallTelemetry": false
}