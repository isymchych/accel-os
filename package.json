{
  "name": "accel-os",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "ai/pi",
    "ai/skills",
    "packages/shared",
    "scripts"
  ],
  "allowScripts": {
    "koffi@2.16.2": true,
    "tilth@0.9.0": true
  },
  "scripts": {
    "fmt": "oxfmt ai/pi ai/skills packages/shared scripts",
    "fmt:check": "oxfmt --check ai/pi ai/skills packages/shared scripts",
    "lint": "oxlint ai/pi ai/skills packages/shared scripts",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^7.0.2"
  }
}
