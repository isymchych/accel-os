{
  "name": "accel-os",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "ai/pi",
    "packages/shared",
    "scripts"
  ],
  "scripts": {
    "fmt": "oxfmt ai/pi packages/shared scripts",
    "fmt:check": "oxfmt --check ai/pi packages/shared scripts",
    "lint": "oxlint ai/pi packages/shared scripts",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^6.0.3"
  }
}
